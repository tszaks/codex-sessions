{
  "name": "@tszaks/codex-sessions",
  "version": "0.2.0",
  "description": "Cross-platform npm installer for the codex-sessions Go CLI",
  "bin": {
    "codex-sessions": "npm/bin/codex-sessions.js"
  },
  "files": [
    "npm/bin",
    "npm/lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node npm/lib/install.cjs",
    "test:npm": "node --test npm/test/*.test.cjs",
    "test": "go test ./... && npm run test:npm",
    "pack:dry-run": "npm pack --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tszaks/codex-sessions.git"
  },
  "homepage": "https://github.com/tszaks/codex-sessions#readme",
  "bugs": {
    "url": "https://github.com/tszaks/codex-sessions/issues"
  },
  "keywords": [
    "codex",
    "cli",
    "go",
    "sessions",
    "npm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "tar": "^7.4.3"
  }
}
